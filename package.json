{
  "name": "test-automation-driven-by-ai-agents",
  "version": "1.2.0",
  "main": "index.js",
  "license": "MIT",
  "author": {
    "name": "tien-pham"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google-cloud/storage": "^7.19.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.3.11",
    "@langchain/core": "^1.1.16",
    "@langchain/google-genai": "^2.1.12",
    "@langchain/langgraph": "^1.0.15",
    "@playwright/cli": "^0.1.1",
    "@playwright/test": "1.50.1",
    "@types/node": "^24.10.1",
    "@types/nunjucks": "^3.2.6",
    "@types/uuid": "9.0.1",
    "google-auth-library": "^10.5.0",
    "nunjucks": "^3.2.4",
    "playwright": "1.50.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "debug": "bun run src/Debug/Debugger.ts",
    "test:run": "bun run src/runner.ts",
    "test:eval": "bun run src/evaluation.ts",
    "test:inspect": "bun run src/inspection.ts",
    "test:allure": "bun run src/Report/generate_allure.ts && allure generate allure-results --clean -o allure-report && allure serve allure-results",
    "test:cleanup": "echo 'Cleanup output folder' && rm -rf output",
    "test:extract": "bun run src/extraction.ts",
    "test:post-run": "bun run test:eval && bun run test:inspect && bun run test:allure",
    "test:e2e": "bun run test:extract && bun run test:run && bun run test:post-run",
    "pwcli": "playwright-cli",
    "claude": "claude"
  },
  "dependencies": {
    "allure-commandline": "^2.36.0",
    "allure-js-commons": "2.15.1",
    "dotenv": "^17.2.3",
    "p-limit": "2",
    "uuid": "9.0.1"
  }
}
